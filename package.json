{
  "name": "openclaw-wizard",
  "version": "1.0.0",
  "description": "A desktop wizard to install and configure OpenClaw on your machine",
  "main": "electron/dist/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"npm run electron:dev\"",
    "build": "next build",
    "electron:dev": "tsc -p electron/tsconfig.json && electron .",
    "electron:build": "tsc -p electron/tsconfig.json",
    "package": "npm run build && npm run electron:build && electron-builder",
    "package:mac": "npm run package -- --mac",
    "package:win": "npm run package -- --win"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.openclaw.wizard",
    "productName": "OpenClaw Setup Wizard",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "electron/dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  }
}
